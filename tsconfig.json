{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
	"jsx": "preserve",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["src/**/*", "tests/**/*"],
  "exclude": ["tests/atomic/test-project/**/*"]
}